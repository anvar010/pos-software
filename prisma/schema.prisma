// Prisma schema for Retail POS System
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  admin
  manager
  cashier
}

enum PaymentMethod {
  CASH
  CARD
  DIGITAL_WALLET
  SPLIT
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  PENDING_REVIEW // flagged when offline sync caused negative stock, etc.
}

enum InventoryReason {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
  OFFLINE_SYNC
  IMPORT
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(admin)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales         Sale[]
  inventoryLogs InventoryLog[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id                String   @id @default(cuid())
  name              String
  sku               String   @unique
  barcode           String?  @unique
  price             Decimal  @db.Decimal(10, 2)
  costPrice         Decimal  @default(0) @db.Decimal(10, 2)
  categoryId        String?
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(5)
  imageUrl          String?
  taxRate           Decimal  @default(0) @db.Decimal(5, 2) // percentage, e.g. 7.50
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems     SaleItem[]
  inventoryLogs InventoryLog[]

  @@index([categoryId])
  @@index([name])
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())

  sales Sale[]

  @@index([phone])
  @@index([email])
}

model Sale {
  id             String        @id @default(cuid())
  // Client-generated id used to de-duplicate sales created while offline.
  localId        String?       @unique
  customerId     String?
  userId         String
  totalAmount    Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod  PaymentMethod @default(CASH)
  // For split payments: [{ method: "CASH", amount: 10.00 }, ...]
  payments       Json?
  status         SaleStatus    @default(COMPLETED)
  // Set true when the sale originated offline and was later synced.
  isSyncedFromOffline Boolean  @default(false)
  note           String?
  createdAt      DateTime      @default(now())

  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User       @relation(fields: [userId], references: [id])
  items    SaleItem[]

  @@index([userId])
  @@index([customerId])
  @@index([createdAt])
  @@index([status])
}

model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  productId      String
  quantity       Int
  unitPrice      Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model InventoryLog {
  id           String          @id @default(cuid())
  productId    String
  changeAmount Int // negative = stock out, positive = stock in
  reason       InventoryReason @default(ADJUSTMENT)
  note         String?
  userId       String?
  createdAt    DateTime        @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([createdAt])
}

// Singleton store/settings row (id is always "store").
model Store {
  id             String   @id @default("store")
  name           String   @default("My Store")
  address        String?
  phone          String?
  email          String?
  logoUrl        String?
  currency       String   @default("INR")
  defaultTaxRate Decimal  @default(0) @db.Decimal(5, 2)
  loyaltyRate    Decimal  @default(1) @db.Decimal(6, 2) // points earned per 1 unit of currency spent
  lowStockDefault Int     @default(5)
  receiptFooter  String?  @default("Thank you for shopping with us!")
  updatedAt      DateTime @updatedAt
}
