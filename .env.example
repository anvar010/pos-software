# ---------------------------------------------------------------------------
# Database (PostgreSQL) — use Supabase, Neon, or any managed Postgres.
# For Supabase use the "Connection pooling" string for DATABASE_URL and the
# direct connection for DIRECT_URL (used by migrations).
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ---------------------------------------------------------------------------
# NextAuth.js (Auth.js v5)
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
# ---------------------------------------------------------------------------
AUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Seed admin account (used by `npm run db:seed`)
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@pos.local"
SEED_ADMIN_PASSWORD="admin1234"
SEED_ADMIN_NAME="Store Admin"
